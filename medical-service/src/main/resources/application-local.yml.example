# =============================================================================
# 阶段 E 本地密钥配置（复制本文件为 application-local.yml，勿提交 Git）
#
# 步骤 0/1 已确认范围（2026-05-28）：
#   - 一期：同步 JSON 接口，不做 SSE 流式
#   - 用户：PATIENT 患者端多轮对话、历史会话、结束摘要、预约引导
#   - 不做：确诊结论、开处方、医生端只读摘要（二期）
#
# 配置方式（二选一）：
#   1. 复制为 application-local.yml，填写 api-key
#   2. 设置系统环境变量 ZHIPU_API_KEY（推荐，无需复制文件）
# =============================================================================

medical:
  ai:
    enabled: true
    api-key: your-zhipu-api-key-here

# Windows PowerShell 临时设置环境变量示例：
#   $env:ZHIPU_API_KEY="你的智谱API密钥"
#
# 连通性自测（将密钥代入环境变量后执行）：
#   curl -s https://open.bigmodel.cn/api/paas/v4/chat/completions ^
#     -H "Authorization: Bearer %ZHIPU_API_KEY%" ^
#     -H "Content-Type: application/json" ^
#     -d "{\"model\":\"glm-4-flash\",\"messages\":[{\"role\":\"user\",\"content\":\"你好\"}],\"max_tokens\":50}"
